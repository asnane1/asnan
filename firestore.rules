rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - email: string (required) - User email
    //   - role: string (required) - 'admin' or 'customer'
    //   - displayName: string (optional) - User display name
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "noorsori@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'customer'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own profile, admins can read any profile
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile as 'customer' (unless they are the default admin)
      // Admins can create any profile
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && (request.resource.data.role == 'customer' || request.auth.token.email == "noorsori@gmail.com")) || 
        isAdmin()
      );
      
      // Users can update their own profile but NOT their role
      // Admins can update any profile including roles
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) || 
        isAdmin()
      );
      
      // Only admins can delete profiles
      allow delete: if isAdmin();
    }

    match /banners/{bannerId} {
      // Anyone can read active banners
      allow read: if true;
      
      // Only admins can manage banners
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Anyone can place an order or view order status, admins manage them
      allow read, write: if true;
    }

    match /payment_gateways/{gatewayId} {
      // Publicly readable for checkout, managed by the server API
      allow read, write: if true;
    }

    match /shipping_zones/{zoneId} {
      // Publicly readable for zones/methods, managed by server API
      allow read, write: if true;

      match /methods/{methodId} {
        allow read, write: if true;
      }
    }
  }
}
